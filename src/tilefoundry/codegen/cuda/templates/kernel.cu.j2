{%- if not entry_host_only %}
__global__ void {{ kernel_name }}_kernel({{ kernel_params_sig }}) {
{%- for wrap in param_wrappers %}
  {{ wrap }}
{%- endfor %}
{{ kernel_body | indent(2, first=true) }}
}

void {{ internal_wrapper_name }}({{ wrapper_params_sig }}) {
{%- for local in wrapper_locals %}
  {{ local }}
{%- endfor %}
  dim3 grid({{ grid_x }}, {{ grid_y }}, {{ grid_z }});
  dim3 block({{ block_x }}, {{ block_y }}, {{ block_z }});
  {{ kernel_name }}_kernel<<<grid, block>>>({{ launch_args }});
}

TVM_FFI_DLL_EXPORT_TYPED_FUNC({{ kernel_name }}, {{ internal_wrapper_name }});
{%- else %}
void {{ internal_wrapper_name }}({{ wrapper_params_sig }}) {
{%- for local in wrapper_locals %}
  {{ local }}
{%- endfor %}
{{ kernel_body | indent(2, first=true) }}
}

TVM_FFI_DLL_EXPORT_TYPED_FUNC({{ kernel_name }}, {{ internal_wrapper_name }});
{%- endif %}
