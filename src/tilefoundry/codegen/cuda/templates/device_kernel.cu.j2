__global__ void {{ kernel_name }}_kernel({{ kernel_params_sig }}) {
{%- for wrap in param_wrappers %}
  {{ wrap }}
{%- endfor %}
{{ kernel_body | indent(2, first=true) }}
}

extern "C" void {{ shim_name }}({{ shim_params_sig }}) {
{%- for cast in shim_casts %}
  {{ cast }}
{%- endfor %}
  dim3 grid(grid_x, grid_y, grid_z);
  dim3 block(block_x, block_y, block_z);
  {{ kernel_name }}_kernel<<<grid, block, dynamic_smem, (cudaStream_t)stream>>>({{ kernel_call_args }});
}
